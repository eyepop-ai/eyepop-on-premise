EYEPOP_URL=https://compute.eyepop.ai
EYEPOP_API_KEY=
EYEPOP_ACCOUNT_UUID=

# Optional: path to the Google service account credentials JSON, relative to the
# repo root. Defaults to .eyepop/creds.json (see README); only set this if you
# store the file elsewhere.
# GOOGLE_CREDS_JSON=.eyepop/creds.json

# Optional: set this only when this host should join Tailscale for camera access.
# TS_AUTHKEY=tskey-auth-xxxxx
# TS_HOSTNAME=eyepop-agent
